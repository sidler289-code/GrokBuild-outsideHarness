{
  "name": "@sidler289-code/cross-harness-review",
  "version": "0.2.0-dev",
  "description": "Grok plugin: lets Grok call external coding harnesses (Claude Code, OpenAI Codex, OpenCode, Antigravity, Cursor) as read-only second-opinion reviewers, with a host scope gate and bounded subprocess execution.",
  "keywords": [
    "grok",
    "grok-plugin",
    "claude-code",
    "codex",
    "opencode",
    "antigravity",
    "cursor",
    "code-review",
    "second-opinion",
    "cross-harness",
    "security",
    "llm"
  ],
  "license": "MIT",
  "author": "sidler289-code",
  "homepage": "https://github.com/sidler289-code/GrokBuild-outsideHarness#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sidler289-code/GrokBuild-outsideHarness.git"
  },
  "bugs": {
    "url": "https://github.com/sidler289-code/GrokBuild-outsideHarness/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "cross-harness-review": "bin/cross-harness-review.cjs"
  },
  "scripts": {
    "test:node": "node --test --test-reporter=spec \"tests/node/**/*.test.cjs\"",
    "test:node:contracts": "node --test --test-reporter=spec tests/node/contracts.test.cjs",
    "test:node:core": "node --test --test-reporter=spec tests/node/core.test.cjs",
    "test:node:entrypoints": "node --test --test-reporter=spec tests/node/entrypoints.test.cjs",
    "test:node:config": "node --test --test-reporter=spec tests/node/config.test.cjs",
    "test:node:discovery": "node --test --test-reporter=spec tests/node/discovery.test.cjs",
    "test:node:role-router": "node --test --test-reporter=spec tests/node/role-router.test.cjs"
  },
  "files": [
    "plugin.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "bin/",
    "lib/",
    "config/",
    "docs/",
    "skills/"
  ],
  "main": "plugin.json"
}
